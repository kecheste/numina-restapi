APP_ENV=development
APP_NAME=Numina API
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=sercret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

OPENAI_API_KEY=

# Password reset: frontend base URL for reset links in emails (e.g. https://app.example.com)
FRONTEND_URL=

# SMTP for sending password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Optional: seed admin user on first run (create one if none exists)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=your-secure-password
